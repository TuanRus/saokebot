# Copy this file to .env and fill in real values. Do NOT commit .env to git.

# Telegram bot token (get it from @BotFather).
BOT_TOKEN=

# Secret used to sign dashboard links. Use a long random string (>= 32 chars) and keep it stable.
# Quick way to generate one: openssl rand -base64 48
DASHBOARD_SECRET=

# Web dashboard URL (the bot uses it to build the /dashboard link).
WEB_URL=http://localhost:5000
