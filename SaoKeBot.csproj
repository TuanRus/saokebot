<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SaoKeBot</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="AWSSDK.DynamoDBv2" Version="4.0.100" />
    <PackageReference Include="AWSSDK.Extensions.NETCore.Setup" Version="4.0.100" />
    <PackageReference Include="Telegram.Bot" Version="19.0.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Dapper" Version="2.1.35" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.0" />
  </ItemGroup>
  <!-- Ensure the Config JSON files are copied to the publish output. -->
  <ItemGroup>
    <Content Update="Config\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
